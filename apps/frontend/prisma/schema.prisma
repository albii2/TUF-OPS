datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  relationMode = "foreignKeys"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                 Int            @id @default(autoincrement())
  email              String         @unique
  password_hash      String?        @map("password_hash")
  name               String?
  role               UserRole       @default(rep)
  managerId          Int?
  created_at         DateTime       @default(now()) @map("created_at")
  updated_at         DateTime       @updatedAt @map("updated_at")

  manager            User?          @relation("ManagerToSubordinates", fields: [managerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subordinates       User[]         @relation("ManagerToSubordinates")
  ownedOrganizations Organization[] @relation("OrganizationOwner")
  ownedOpportunities Opportunity[]  @relation("OpportunityOwner")
  opportunityEvents OpportunityEvent[] @relation("OpportunityEventsByUser")
  drops              Drop[]         @relation("DropSeller")

  @@map("users")
}

model Organization {
  id              Int           @id @default(autoincrement())
  name            String
  ownerId         Int?
  owner           User?         @relation("OrganizationOwner", fields: [ownerId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  opportunities   Opportunity[]
  zoho_account_id String?       @unique @map("zoho_account_id")
  status          OrganizationStatus @default(active)

  @@map("organizations")
}

model Opportunity {
  id                 Int                 @id @default(autoincrement())
  organization_id    Int?
  organization       Organization?       @relation(fields: [organization_id], references: [id], onDelete: SetNull, onUpdate: Cascade)
  name               String
  stage              OpportunityStage    @default(lead)
  ownerId            Int?
  owner              User?               @relation("OpportunityOwner", fields: [ownerId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  last_contact_date  DateTime?           @map("last_contact_date")
  probability        Int?
  estimated_value    Decimal             @default(0) @db.Decimal(10, 2) @map("estimated_value")
  nextStep           String?             @map("next_step")
  nextStepDueDate    DateTime?           @map("next_step_due_date")
  close_date         DateTime?           @map("close_date")
  created_at         DateTime            @default(now()) @map("created_at")
  updated_at         DateTime            @updatedAt @map("updated_at")
  zoho_deal_id       String?             @unique @map("zoho_deal_id")
  events             OpportunityEvent[]

  @@map("opportunities")
}


model OpportunityEvent {
  id            Int                  @id @default(autoincrement())
  opportunityId Int                  @map("opportunity_id")
  opportunity   Opportunity          @relation(fields: [opportunityId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  actorUserId   Int                  @map("actor_user_id")
  actorUser     User                 @relation("OpportunityEventsByUser", fields: [actorUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  eventType     OpportunityEventType @map("event_type")
  fromStage     OpportunityStage?    @map("from_stage")
  toStage       OpportunityStage?    @map("to_stage")
  metadata      Json?
  created_at    DateTime             @default(now()) @map("created_at")

  @@index([opportunityId, created_at])
  @@index([actorUserId, created_at])
  @@map("opportunity_events")
}

enum OrganizationStatus {
  active
  inactive
  archived
}

enum OpportunityStage {
  lead
  contacted
  mockup
  sample
  invoice
  closed_won
  closed_lost
}

enum UserRole {
    admin
    director
    rep
}

enum OpportunityEventType {
  stage_changed
  owner_changed
}

model Drop {
  id             Int          @id @default(autoincrement())
  slug           String       @unique
  title          String
  description    String?
  heroImageUrl   String?      @map("hero_image_url")
  depositOpensAt DateTime?    @map("deposit_opens_at")
  balanceDueAt   DateTime     @map("balance_due_at")
  releaseAt      DateTime     @map("release_at")
  depositAmount  Decimal      @db.Decimal(10, 2) @map("deposit_amount")
  fullPrice      Decimal      @db.Decimal(10, 2) @map("full_price")
  sellerUserId   Int?         @map("seller_user_id")
  seller         User?        @relation("DropSeller", fields: [sellerUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  created_at     DateTime     @default(now()) @map("created_at")
  updated_at     DateTime     @updatedAt @map("updated_at")
  sizes          DropSize[]
  orders         Order[]
  reminders      Reminder[]

  @@map("drops")
}

model DropSize {
  id                Int      @id @default(autoincrement())
  dropId            Int      @map("drop_id")
  drop              Drop     @relation(fields: [dropId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  sizeLabel         String   @map("size_label")
  totalInventory    Int      @map("total_inventory")
  reservedInventory Int      @default(0) @map("reserved_inventory")
  soldInventory     Int      @default(0) @map("sold_inventory")
  created_at        DateTime @default(now()) @map("created_at")
  updated_at        DateTime @updatedAt @map("updated_at")

  @@unique([dropId, sizeLabel])
  @@map("drop_sizes")
}

model Customer {
  id          Int       @id @default(autoincrement())
  fullName    String    @map("full_name")
  email       String
  phone       String?
  created_at  DateTime  @default(now()) @map("created_at")
  updated_at  DateTime  @updatedAt @map("updated_at")
  orders      Order[]
  reminders   Reminder[]

  @@map("customers")
}

model Order {
  id              Int         @id @default(autoincrement())
  publicOrderId   String      @unique @map("public_order_id")
  dropId          Int         @map("drop_id")
  drop            Drop        @relation(fields: [dropId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  customerId      Int         @map("customer_id")
  customer        Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  sizeLabel       String      @map("size_label")
  quantity        Int         @default(1)
  unitPrice       Decimal     @db.Decimal(10, 2) @map("unit_price")
  depositPaid     Decimal     @db.Decimal(10, 2) @default(0) @map("deposit_paid")
  balanceOwed     Decimal     @db.Decimal(10, 2) @default(0) @map("balance_owed")
  balanceDueAt    DateTime    @map("balance_due_at")
  paidInFullAt    DateTime?   @map("paid_in_full_at")
  cancelledAt     DateTime?   @map("cancelled_at")
  status          OrderStatus @default(deposit_paid)
  created_at      DateTime    @default(now()) @map("created_at")
  updated_at      DateTime    @updatedAt @map("updated_at")
  payments        Payment[]

  @@index([dropId, status])
  @@map("orders")
}

model Payment {
  id              Int           @id @default(autoincrement())
  orderId          Int          @map("order_id")
  order            Order        @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  amount           Decimal      @db.Decimal(10, 2)
  paymentType      PaymentType  @map("payment_type")
  status           PaymentStatus @default(succeeded)
  paymentMethodRef String?      @map("payment_method_ref")
  created_at       DateTime     @default(now()) @map("created_at")

  @@map("payments")
}

model Reminder {
  id             Int            @id @default(autoincrement())
  dropId          Int?          @map("drop_id")
  drop            Drop?         @relation(fields: [dropId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  customerId      Int           @map("customer_id")
  customer        Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  orderId         Int?          @map("order_id")
  reminderType    ReminderType  @map("reminder_type")
  scheduledFor    DateTime      @map("scheduled_for")
  sentAt          DateTime?     @map("sent_at")
  created_at      DateTime      @default(now()) @map("created_at")

  @@map("reminders")
}

enum OrderStatus {
  deposit_paid
  overdue
  paid_in_full
  fulfilled
  cancelled
  refunded
}

enum PaymentStatus {
  pending
  succeeded
  failed
}

enum PaymentType {
  deposit
  balance
}

enum ReminderType {
  payment_due
  release_day
  pickup_ready
}
