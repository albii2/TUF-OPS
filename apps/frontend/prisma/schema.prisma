
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                 Int            @id @default(autoincrement())
  email              String         @unique
  password_hash      String?        @map("password_hash")
  name               String?
  role               UserRole       @default(rep)
  managerId          Int?
  created_at         DateTime       @default(now()) @map("created_at")
  updated_at         DateTime       @updatedAt @map("updated_at")

  manager            User?          @relation("ManagerToSubordinates", fields: [managerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subordinates       User[]         @relation("ManagerToSubordinates")
  ownedOrganizations Organization[] @relation("OrganizationOwner")
  ownedOpportunities Opportunity[]  @relation("OpportunityOwner")
  opportunityEvents OpportunityEvent[] @relation("OpportunityEventsByUser")

  @@map("users")
}

enum UserRole {
  ADMIN
  DIRECTOR
  REP
}

model Organization {
  id          Int           @id @default(autoincrement())
  name        String
  owner       User?         @relation("Owner", fields: [ownerId], references: [id])
  ownerId     Int?          @map("owner_id")
  opportunities Opportunity[]

  @@map("organizations")
}

model Opportunity {
  id                 Int                  @id @default(autoincrement())
  organization       Organization         @relation(fields: [organizationId], references: [id])
  organizationId     Int                  @map("organization_id")
  name               String
  stage              OpportunityStage    @default(lead)
  ownerId            Int?
  owner              User?               @relation("OpportunityOwner", fields: [ownerId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  last_contact_date  DateTime?           @map("last_contact_date")
  probability        Int?
  estimated_value    Decimal             @default(0) @db.Decimal(10, 2) @map("estimated_value")
  nextStep           String?             @map("next_step")
  nextStepDueDate    DateTime?           @map("next_step_due_date")
  close_date         DateTime?           @map("close_date")
  created_at         DateTime            @default(now()) @map("created_at")
  updated_at         DateTime            @updatedAt @map("updated_at")
  zoho_deal_id       String?             @unique @map("zoho_deal_id")
  events             OpportunityEvent[]

  @@map("opportunities")
}


model OpportunityEvent {
  id            Int                  @id @default(autoincrement())
  opportunityId Int                  @map("opportunity_id")
  opportunity   Opportunity          @relation(fields: [opportunityId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  actorUserId   Int                  @map("actor_user_id")
  actorUser     User                 @relation("OpportunityEventsByUser", fields: [actorUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  eventType     OpportunityEventType @map("event_type")
  fromStage     OpportunityStage?    @map("from_stage")
  toStage       OpportunityStage?    @map("to_stage")
  metadata      Json?
  created_at    DateTime             @default(now()) @map("created_at")

  @@index([opportunityId, created_at])
  @@index([actorUserId, created_at])
  @@map("opportunity_events")
}

enum OrganizationStatus {
  active
  inactive
  archived
}

enum OpportunityStage {
  lead
  contacted
  mockup
  sample
  invoice
  closed_won
  closed_lost
}

enum OpportunityEventType {
  stage_changed
  owner_changed
  next_step_set
  due_date_set
  note_added
}

enum DealType {
  UNIFORMS
  TEAM_STORES
  LETTERMAN_JACKETS
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  COMPLETED
  CANCELED
}

enum OpportunityEventType {
  stage_changed
  owner_changed
}
