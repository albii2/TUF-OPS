
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            Int           @id @default(autoincrement())
  email         String        @unique
  name          String?
  role          UserRole      @default(REP)
  manager       User?         @relation("ManagerSubordinates", fields: [managerId], references: [id])
  managerId     Int?          @map("manager_id")
  subordinates  User[]        @relation("ManagerSubordinates")
  ownedOrgs     Organization[]@relation("Owner")
  ownedOpps     Opportunity[] @relation("Owner")
  events        OpportunityEvent[]

  @@map("users")
}

enum UserRole {
  ADMIN
  DIRECTOR
  REP
}

model Organization {
  id          Int           @id @default(autoincrement())
  name        String
  owner       User?         @relation("Owner", fields: [ownerId], references: [id])
  ownerId     Int?          @map("owner_id")
  opportunities Opportunity[]

  @@map("organizations")
}

model Opportunity {
  id                 Int                  @id @default(autoincrement())
  organization       Organization         @relation(fields: [organizationId], references: [id])
  organizationId     Int                  @map("organization_id")
  name               String
  stage              OpportunityStage     @default(lead)
  owner              User?                @relation("Owner", fields: [ownerId], references: [id])
  ownerId            Int?                 @map("owner_id")
  last_contact_date  DateTime?            @map("last_contact_date")
  probability        Float?
  estimated_value    Decimal?             @db.Decimal(10, 2) @map("estimated_value")
  nextStep           String?              @map("next_step")
  nextStepDueDate    DateTime?            @map("next_step_due_date")
  close_date         DateTime?            @map("close_date")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")
  zoho_deal_id       String?              @unique @map("zoho_deal_id")
  mockup             Mockup?              // Relation to the Mockup model
  events             OpportunityEvent[]

  // Commission Fields (for future module)
  deal_type          DealType?   @map("deal_type")
  cost_of_goods_sold Decimal?    @db.Decimal(10, 2) @map("cost_of_goods_sold")
  gross_profit       Decimal?    @db.Decimal(10, 2) @map("gross_profit") // Can be calculated: estimated_value - cost_of_goods_sold

  order              Order?      // Relation to the Order model

  @@map("opportunities")
}

model Mockup {
  id             Int           @id @default(autoincrement())
  opportunity    Opportunity   @relation(fields: [opportunityId], references: [id])
  opportunityId  Int           @unique @map("opportunity_id")
  status         String        @default("pending")
  primaryColor   String?
  secondaryColor String?
  tertiaryColor  String?
  jerseyNumbers  String?
  logoUrl        String?
  notes          String?
  trelloCardId   String?       @unique

  @@map("mockups")
}

model OpportunityEvent {
  id            Int                  @id @default(autoincrement())
  opportunity   Opportunity          @relation(fields: [opportunityId], references: [id])
  opportunityId Int                  @map("opportunity_id")
  actorUser     User                 @relation(fields: [actorUserId], references: [id])
  actorUserId   Int                  @map("actor_user_id")
  eventType     OpportunityEventType @map("event_type")
  fromStage     OpportunityStage?    @map("from_stage")
  toStage       OpportunityStage?    @map("to_stage")
  metadata      Json?
  createdAt     DateTime             @default(now()) @map("created_at")

  @@map("opportunity_events")
}

model Order {
  id            Int          @id @default(autoincrement())
  orderNumber   String       @unique @map("order_number")
  opportunity   Opportunity  @relation(fields: [opportunityId], references: [id])
  opportunityId Int          @unique @map("opportunity_id")
  status        OrderStatus  @default(PENDING)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("orders")
}

enum OpportunityStage {
  lead
  contacted
  mockup
  sample
  invoice
  closed_won
  closed_lost
}

enum OpportunityEventType {
  stage_changed
  owner_changed
  next_step_set
  due_date_set
  note_added
}

enum DealType {
  UNIFORMS
  TEAM_STORES
  LETTERMAN_JACKETS
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  COMPLETED
  CANCELED
}
