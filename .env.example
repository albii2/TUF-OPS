# Copy to .env at the repository root for local development.
DATABASE_URL=postgresql://localhost:5432/tuf_dev
TEST_DATABASE_URL=postgresql://localhost:5432/tuf_test
AUTH_TOKEN_SECRET=your-secret-here
INITIAL_OWNER_CREDENTIAL=0000
PORT=4000
NODE_ENV=development

# Optional: used by `pnpm db:seed:test-accounts`; required in production-like environments.
TEST_ACCOUNT_CREDENTIAL=9999
ALLOW_TEST_ACCOUNT_SEED=false
