{
  "name": "tuf-ops-monorepo",
  "private": true,
  "scripts": {
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:backend": "pnpm --filter backend dev",
    "postinstall": "cd apps/frontend && pnpm prisma generate",
    "test:e2e": "playwright test",
    "test:e2e:prod": "pnpm --filter frontend build && playwright test",
    "db:railway:grant": "pnpm --filter frontend exec prisma db execute --file ../../prisma/sql/railway-permissions.sql --schema ../../prisma/schema.prisma"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "pnpm": "^9.1.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
