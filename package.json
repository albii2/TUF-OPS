{
  "name": "tuf-ops-monorepo",
  "private": true,
  "scripts": {
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:backend": "pnpm --filter backend dev",
    "postinstall": "cd apps/frontend && pnpm prisma generate",
    "db:seed": "cd apps/frontend && pnpm exec dotenv -e ../../.env -- tsx ../../prisma/seed.ts",
    "db:push": "cd apps/frontend && pnpm exec dotenv -e ../../.env -- prisma db push",
    "test:e2e": "playwright test",
    "test:e2e:prod": "pnpm --filter frontend build && playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "pnpm": "^9.1.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5"
  }
}